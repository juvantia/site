generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model District {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  description String
  type        String     // e.g., "government", "residential_high", "residential_low", "industrial", "agricultural"
  x           Int        // Starting X coordinate on the global grid
  y           Int        // Starting Y coordinate on the global grid
  width       Int        // Width in meters
  height      Int        // Height in meters
  tiles       LandTile[]
  salesZones  SalesZone[]
  buildings   Building[]
}

model Building {
  id         Int      @id @default(autoincrement())
  districtId Int
  district   District @relation(fields: [districtId], references: [id])
  x          Int      // Relative X
  y          Int      // Relative Y
  width      Int      // Display width in meters
  height     Int      // Display height in meters
  imageUrl   String   // Path to SVG
  name       String?
}

model SalesZone {
  id         Int      @id @default(autoincrement())
  districtId Int
  district   District @relation(fields: [districtId], references: [id])
  x          Int
  y          Int
  width      Int
  height     Int
}

model LandTile {
  id         Int      @id @default(autoincrement())
  x          Int      // Global X coordinate
  y          Int      // Global Y coordinate
  districtId Int
  district   District @relation(fields: [districtId], references: [id])
  status     String   @default("AVAILABLE") // AVAILABLE, SOLD, RESERVED, ROAD, INFRASTRUCTURE
  price      Float?   // Price in JVD/ETH
  owner      String?  // Wallet address or User ID
  
  @@unique([x, y])
}

model Memorandum {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  name        String
  contact     String   // Email
  readyToBuild Boolean
  experience  String   // Text description or links
  photos      String?  // JSON array of photo URLs (max 5)
  status      String   @default("PENDING")
}

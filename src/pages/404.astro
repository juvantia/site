---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="404 - Sector Not Found | Juvantia">
    <div style="
        min-height: 80vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 2rem;
    ">
        <h1 style="
            font-family: 'Cinzel', serif;
            font-size: clamp(4rem, 15vw, 8rem);
            background: linear-gradient(135deg, #ff4757 0%, #ffa502 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin: 0;
            line-height: 1;
            filter: drop-shadow(0 0 20px rgba(255, 71, 87, 0.4));
        ">404</h1>
        
        <div style="
            height: 1px;
            width: 100px;
            background: rgba(255, 71, 87, 0.3);
            margin: 2rem 0;
        "></div>

        <h2 style="
            font-family: 'Cinzel', serif;
            color: #E6F0EB;
            letter-spacing: 0.2em;
            text-transform: uppercase;
            font-size: 1.2rem;
            margin-bottom: 1.5rem;
        ">Sector Not Found</h2>

        <p style="
            font-family: 'Space Grotesk', sans-serif;
            color: rgba(185, 203, 185, 0.7);
            max-width: 400px;
            line-height: 1.6;
            margin-bottom: 3rem;
        ">
            The coordinates you requested do not exist within the Juvantia network. Your rover has drifted into unmapped territory.
        </p>

        <a href="/" style="
            font-family: 'Space Grotesk', sans-serif;
            padding: 1rem 2.5rem;
            border: 1px solid rgba(0, 255, 136, 0.4);
            color: #00FF88;
            text-decoration: none;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            font-size: 0.8rem;
            transition: all 0.3s ease;
            background: rgba(0, 255, 136, 0.05);
        " onmouseover="this.style.background='rgba(0, 255, 136, 0.15)'; this.style.boxShadow='0 0 20px rgba(0, 255, 136, 0.2)'" 
           onmouseout="this.style.background='rgba(0, 255, 136, 0.05)'; this.style.boxShadow='none'">
            Return to Base
        </a>
    </div>
</MainLayout>
